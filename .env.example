# Copy this file to .env and fill in the values for your machine.
# .env is gitignored — each user keeps their own local copy.

# Root of the KAPA data directory.
# /g/lu/data/kapa and /g3/data/kapa are symlinked to the same location
# on the MULab cluster, so either path works here.
KAPA_DATA_PATH=/g/lu/data/kapa/

# Directory containing the MAOS .conf files.
MAOS_CONFIG_PATH=/u/nstieg/work/ao/keck/maos/keck_maos/kapa/

# Folder containing MASS/DIMM seeing data files.
MASSDIMM_DATA_PATH=/u/nstieg/work/ao/keck/massdimm/

# Overrides for paarti map files.
# Leave commented out to auto-detect from the paarti package installation.
# PAARTI_SUBAP_MAP_PATH=
# PAARTI_ACT_MAP_PATH=
